# Database (Vercel Postgres, Supabase, Neon, etc.)
DATABASE_URL="postgresql://user:pass@host:5432/omega"

# MinIO / S3-compatible storage
MINIO_ENDPOINT="https://your-s3-endpoint.com"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET="omega-images"
MINIO_PUBLIC_URL="https://your-bucket-url.com/omega-images"

# Auth
JWT_SECRET="generate-a-strong-secret-here"

# App
NEXT_PUBLIC_APP_URL="https://your-domain.com"
